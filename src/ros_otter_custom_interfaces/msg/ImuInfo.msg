# $PMARIMU,<roll>,<pitch>,<yaw>,<p>,<q>,<r>*<checksum>
float64 roll                 # Roll angle (degrees or radians)
float64 pitch                # Pitch angle
float64 yaw                  # Yaw angle
float64 p                    # Angular velocity around X axis
float64 q                    # Angular velocity around Y axis
float64 r                    # Angular velocity around Z axis